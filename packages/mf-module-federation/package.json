{
  "name": "@gluezero/mf-module-federation",
  "version": "2.0.0-rc.0",
  "description": "GlueZero Module Federation loader (webpack 5 + @module-federation/runtime v0.x) — experimental @0.x.0 V2.0 GA — share scope warn + 5 error codes",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./augment": {
      "types": "./dist/augment.d.ts",
      "import": "./dist/augment.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "experimental"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "ci:publint": "publint",
    "ci:attw": "attw --pack . --profile esm-only",
    "ci:gate:mf": "pnpm run typecheck && pnpm run build && pnpm run test && pnpm run ci:publint && pnpm run ci:attw && size-limit"
  },
  "peerDependencies": {
    "@gluezero/core": "workspace:^",
    "@gluezero/microfrontends": "workspace:^",
    "@module-federation/runtime": ">=2.0.0 <3.0.0"
  },
  "peerDependenciesMeta": {
    "@gluezero/core": {
      "optional": false
    },
    "@gluezero/microfrontends": {
      "optional": false
    },
    "@module-federation/runtime": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/microfrontends": "workspace:*",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "jsdom": "29.1.0",
    "playwright": "1.59.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "size-limit": [
    {
      "name": "@gluezero/mf-module-federation (gzip)",
      "path": "dist/index.js",
      "limit": "5 KB",
      "gzip": true
    },
    {
      "name": "@gluezero/mf-module-federation/augment (gzip)",
      "path": "dist/augment.js",
      "limit": "1 KB",
      "gzip": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/mf-module-federation"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/mf-module-federation#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "gluezero",
    "module-federation",
    "webpack",
    "runtime",
    "microfrontend",
    "experimental"
  ]
}
