{
  "name": "@gluezero/web-components",
  "version": "2.0.0-alpha.0",
  "description": "GlueZero Web Components adapter — GlueZeroElement base class opzionale + AbortController cleanup + subpath /lit con Lit 3.x ReactiveController + Mixin",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lit": {
      "types": "./dist/lit/index.d.ts",
      "import": "./dist/lit/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "experimental"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "ci:publint": "publint",
    "ci:attw": "attw --pack . --profile esm-only",
    "ci:gate:wc": "pnpm run typecheck && pnpm run build && pnpm run test && pnpm run ci:publint && pnpm run ci:attw && size-limit"
  },
  "peerDependencies": {
    "@gluezero/core": "workspace:^",
    "@gluezero/microfrontends": "workspace:^",
    "lit": ">=3.0.0 <4.0.0"
  },
  "peerDependenciesMeta": {
    "@gluezero/core": {
      "optional": false
    },
    "@gluezero/microfrontends": {
      "optional": false
    },
    "lit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/microfrontends": "workspace:*",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "jsdom": "29.1.0",
    "lit": "3.3.0",
    "playwright": "1.59.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "size-limit": [
    {
      "name": "@gluezero/web-components (gzip)",
      "path": "dist/index.js",
      "limit": "8 KB",
      "gzip": true
    },
    {
      "name": "@gluezero/web-components/lit (gzip)",
      "path": "dist/lit/index.js",
      "limit": "3 KB",
      "gzip": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/web-components"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/web-components#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "gluezero",
    "web-components",
    "custom-elements",
    "lit",
    "microfrontend",
    "adapter",
    "esm"
  ]
}
