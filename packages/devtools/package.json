{
  "name": "@gluezero/devtools",
  "version": "1.0.0",
  "description": "GlueZero devtools \u2014 Event/Mapping/Route Inspector, MetricsCollector (simil-OpenMetrics), PauseController",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/mapper": "workspace:*",
    "@gluezero/routing": "workspace:*",
    "nanoid": "5.1.11",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "29.1.0",
    "playwright": "1.59.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/devtools#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "browser",
    "debug",
    "devtools",
    "esm",
    "frontend",
    "inspector",
    "javascript",
    "metrics",
    "observability",
    "openmetrics",
    "typescript"
  ]
}
