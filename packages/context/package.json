{
  "name": "@gluezero/context",
  "version": "2.0.0-alpha.0",
  "description": "GlueZero runtime context module + per-MF mapping integration — reactive state container with selector subscribe + writableKeys ACL + canonical mapper reuse",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./augment": {
      "types": "./dist/augment.d.ts",
      "import": "./dist/augment.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "experimental"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gluezero/core": "workspace:^",
    "@gluezero/microfrontends": "workspace:^",
    "@gluezero/mapper": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@gluezero/core": {
      "optional": false
    },
    "@gluezero/microfrontends": {
      "optional": false
    },
    "@gluezero/mapper": {
      "optional": false
    }
  },
  "devDependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/microfrontends": "workspace:*",
    "@gluezero/mapper": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "jsdom": "29.1.0"
  },
  "size-limit": [
    {
      "name": "@gluezero/context (gzip)",
      "path": "dist/index.js",
      "limit": "4 KB",
      "gzip": true
    },
    {
      "name": "@gluezero/context/augment (gzip)",
      "path": "dist/augment.js",
      "limit": "1 KB",
      "gzip": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/context"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/context#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "browser",
    "context",
    "esm",
    "frontend",
    "javascript",
    "micro-frontend",
    "microfrontend",
    "runtime-context",
    "selector",
    "state",
    "subscribe",
    "typescript"
  ]
}
