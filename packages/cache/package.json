{
  "name": "@gluezero/cache",
  "version": "1.0.0",
  "description": "Cache layer per GlueZero (Phase 6 \u2014 MemoryCacheAdapter LRU bounded + scope user-aware + cache-then-network ordering \u2014 D-155/D-156/D-157/D-158)",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/mapper": "workspace:*",
    "@gluezero/routing": "workspace:*",
    "@gluezero/gateway": "workspace:*",
    "nanoid": "5.1.11",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "29.1.0",
    "playwright": "1.59.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/cache"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/cache#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues"
}
