{
  "name": "@gluezero/mf-esm",
  "version": "2.0.0-rc.0",
  "description": "GlueZero ESM dynamic import loader for micro-frontends — import(url) + AbortSignal timeout + module normalization",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./augment": {
      "types": "./dist/augment.d.ts",
      "import": "./dist/augment.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "tag": "experimental"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@gluezero/core": "workspace:^",
    "@gluezero/microfrontends": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@gluezero/core": {
      "optional": false
    },
    "@gluezero/microfrontends": {
      "optional": false
    }
  },
  "devDependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/microfrontends": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "playwright": "1.59.1",
    "jsdom": "29.1.0"
  },
  "size-limit": [
    {
      "name": "@gluezero/mf-esm (gzip)",
      "path": "dist/index.js",
      "limit": "3 KB",
      "gzip": true
    },
    {
      "name": "@gluezero/mf-esm/augment (gzip)",
      "path": "dist/augment.js",
      "limit": "1 KB",
      "gzip": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/mf-esm"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/mf-esm#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "browser",
    "esm",
    "frontend",
    "import",
    "javascript",
    "lifecycle",
    "loader",
    "micro-frontend",
    "microfrontend",
    "typescript"
  ]
}
