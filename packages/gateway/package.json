{
  "name": "@gluezero/gateway",
  "version": "1.0.0",
  "description": "HTTP Gateway centralizzato + adapter realtime per GlueZero (Phase 3 HTTP + Phase 4 realtime SSE/WS)",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./sse-ws": {
      "types": "./dist/sse-ws/index.d.ts",
      "import": "./dist/sse-ws/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "./src/augment.ts",
    "**/augment.js",
    "**/augment.ts"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:msw": "vitest run --passWithNoTests src/sse-ws/__integration__/msw-",
    "test:browser": "vitest run --config vitest.browser.config.ts --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "publint": "publint --strict",
    "attw": "attw --pack --profile=esm-only",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/mapper": "workspace:*",
    "@gluezero/routing": "workspace:*",
    "nanoid": "5.1.9",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "jsdom": "29.1.0",
    "msw": "2.13.6",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/gateway"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/gateway#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues"
}
