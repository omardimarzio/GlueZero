{
  "name": "@gluezero/core",
  "version": "1.0.0",
  "description": "Core event broker (pub/sub, plugin registry, lifecycle, BrokerEvent) for GlueZero",
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "nanoid": "5.1.9",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "jsdom": "29.1.0"
  },
  "size-limit": [
    {
      "name": "@gluezero/core (gzip)",
      "path": "dist/index.js",
      "limit": "8 KB",
      "gzip": true
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/core#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues"
}
