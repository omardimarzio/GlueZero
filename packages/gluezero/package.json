{
  "name": "@gluezero/gluezero",
  "version": "1.0.0",
  "description": "GlueZero \u2014 frontend integration runtime: pub/sub broker, canonical mapping, declarative routing, HTTP gateway, realtime, worker, cache, devtools",
  "license": "MIT",
  "author": "Omar Di Marzio",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/augment.js",
    "**/augment.{js,ts}"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gluezero/core": "workspace:*",
    "@gluezero/mapper": "workspace:*",
    "@gluezero/routing": "workspace:*",
    "@gluezero/gateway": "workspace:*",
    "@gluezero/worker": "workspace:*",
    "@gluezero/cache": "workspace:*",
    "@gluezero/devtools": "workspace:*",
    "valibot": "1.3.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omardimarzio/GlueZero.git",
    "directory": "packages/gluezero"
  },
  "homepage": "https://github.com/omardimarzio/GlueZero/tree/main/packages/gluezero#readme",
  "bugs": "https://github.com/omardimarzio/GlueZero/issues",
  "keywords": [
    "browser",
    "cache",
    "esm",
    "frontend",
    "frontend-architecture",
    "gateway",
    "gluezero",
    "javascript",
    "micro-frontend",
    "monorepo",
    "pub-sub",
    "routing",
    "typescript",
    "worker"
  ]
}
