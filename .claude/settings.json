{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": ["Bash(gsd-sdk query *)", "Bash(npm view *)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .planning/scripts/update-tracker.sh 2>&1 | head -5 || true"
          }
        ]
      }
    ]
  }
}
