{
  "name": "sembridge-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' --if-present run build",
    "test": "pnpm -r --filter='./packages/*' --if-present run test",
    "test:watch": "pnpm -r --filter='./packages/*' --if-present run test:watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --filter='./packages/*' --if-present run typecheck",
    "ci:publint": "pnpm --filter @sembridge/core exec publint",
    "ci:attw": "pnpm --filter @sembridge/core exec attw --pack --profile=esm-only",
    "ci:size": "size-limit",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "2.31.0",
    "vitest": "4.1.5",
    "@vitest/browser": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "playwright": "1.59.1",
    "jsdom": "29.1.0",
    "happy-dom": "20.9.0",
    "msw": "2.13.6",
    "tsup": "8.5.1",
    "typedoc": "0.28.19",
    "publint": "0.3.18",
    "@arethetypeswrong/cli": "0.18.2",
    "size-limit": "12.1.0",
    "@size-limit/preset-small-lib": "12.1.0"
  },
  "size-limit": [
    {
      "name": "@sembridge/core (gzip)",
      "path": "packages/core/dist/index.js",
      "limit": "8 KB",
      "gzip": true
    },
    {
      "name": "@sembridge/mapper (gzip)",
      "path": "packages/mapper/dist/index.js",
      "limit": "5 KB",
      "gzip": true
    }
  ]
}
