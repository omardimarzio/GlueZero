{
  "$schema": "https://typedoc.org/schema.json",
  "name": "GlueZero v2.0 API",
  "out": "docs/v2/api",
  "entryPointStrategy": "expand",
  "entryPoints": [
    "packages/core/src/index.ts",
    "packages/mapper/src/index.ts",
    "packages/routing/src/index.ts",
    "packages/gateway/src/index.ts",
    "packages/worker/src/index.ts",
    "packages/cache/src/index.ts",
    "packages/theme/src/index.ts",
    "packages/devtools/src/index.ts",
    "packages/gluezero/src/index.ts",
    "packages/microfrontends/src/index.ts",
    "packages/mf-esm/src/index.ts",
    "packages/context/src/index.ts",
    "packages/permissions/src/index.ts",
    "packages/compat/src/index.ts",
    "packages/isolation/src/index.ts",
    "packages/fallbacks/src/index.ts",
    "packages/mf-web-component/src/index.ts",
    "packages/mf-iframe/src/index.ts",
    "packages/mf-module-federation/src/index.ts",
    "packages/mf-single-spa/src/index.ts",
    "packages/react/src/index.ts",
    "packages/web-components/src/index.ts"
  ],
  "exclude": [
    "**/test/**",
    "**/__tier1__/**",
    "**/__tier3__/**",
    "**/__bc_replay__/**",
    "**/__integration__/**",
    "**/__browser__/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.bench.ts"
  ],
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "docs/v2/index.md",
  "includeVersion": true,
  "githubPages": false,
  "skipErrorChecking": true,
  "excludeInternal": true,
  "excludePrivate": true,
  "lang": "it",
  "navigationLinks": {
    "PRD v2.0": "https://github.com/omardimarzio/GlueZero/blob/main/prd_2.0.0.md",
    "Migration guide": "https://github.com/omardimarzio/GlueZero/blob/main/docs/v2/17-migration-guide.md",
    "GitHub": "https://github.com/omardimarzio/GlueZero"
  }
}
